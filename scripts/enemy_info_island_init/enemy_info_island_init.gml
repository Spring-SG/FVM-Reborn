function enemy_info_island_init(){
	enemy_info_island_register_init()
	register_enemy_info_island("normal_mouse","很普通的老鼠，没有特殊能力。遇到可攻击的卡片就会啃食。")
	register_enemy_info_island("football_fan_mouse","足球帽使它的脑门更硬了。")
	register_enemy_info_island("iron_pan_mouse","头顶的铁锅使它能够承受大量伤害。")
	register_enemy_info_island("skateboard_mouse","入场时以0.9的速度移动，遇到第一个卡片后，会使用滑板翻越该卡片，并\n落至该卡片的后面一格，落地后移动速度降低至0.3。无法越过重型防御。\nTip：可以将低耗火的卡放在它面前，使其提前使用滑板。")
	register_enemy_info_island("zombie_with_flower_pot","入场时以0.36的速度移动，花盆被击落后，会进入发怒状态，速度提高至\n0.6，攻击间隔减半。")
	register_enemy_info_island("landlady_mouse","盾牌可以抵挡直射伤害，并免疫其带来的负面效果，但是无法抵挡投掷和穿\n透伤害。")
	register_enemy_info_island("ninja_mouse","入场后以1.2的速度冲刺，对第一个碰到的卡片造成10点冲撞伤害，随后停\n止，并在上下左右各召唤一个小喽啰，初次召唤后移动速度降低至0.26。如\n果没有碰到卡片，则会在4.5秒后停止冲刺并进行初次召唤。初次召唤后，\n如果有小喽啰死亡，则会再次召唤并补充阵亡的小喽啰，冷却为15秒。\nTip：可以利用低耗火的卡片挡住冲锋，利用穿透或群伤卡片快速清除小喽\n啰。")
	register_enemy_info_island("minion_mouse","由忍者鼠召唤出的小喽啰，没有特殊能力。")
	register_enemy_info_island("repairman_mouse","入场时以0.6的速度移动，遇到防御类卡片则会将梯子摆在其上，使鼠军可\n以翻越该卡片。失去梯子后移动速度降低至0.3。\nTip：铲除带有梯子的卡片，或使用炸弹，均可以移除梯子。")
	register_enemy_info_island("machine_mouse","遇到第一个卡片后会停下，并在1秒的起爆动作后自爆，对3*3范围内的所有\n卡片造成[攻击力]点伤害。\nTip：可以利用低耗火的卡片使其提前爆炸。")
	register_enemy_info_island("kangaroo","遇到卡片后，会在短暂的停顿后跳过该卡片。无法越过重型防御。\nTip：尽量避免在前排放置卡片，这会让它更快接近基地！")
	register_enemy_info_island("diver_mouse","入场后会跳至水中并潜水，免疫大部分直线子弹的伤害，但无法免疫投手和\n追踪卡片的伤害。啃食时会露出水面。")
	register_enemy_info_island("paper_boat_mouse","很普通的水上老鼠，没有特殊能力。")
	register_enemy_info_island("duck_mouse","足球帽使他的脑门更硬了。")
	register_enemy_info_island("tropical_fish_mouse","头顶的铁锅使他能够承受大量伤害。")
	register_enemy_info_island("lambo_mouse","会随着一大波老鼠一起出现。")
	register_enemy_info_island("butterfly_mouse","盾牌可以抵挡直射伤害，并免疫其带来的负面效果，但是无法抵挡投掷和穿\n透伤害。")
	register_enemy_info_island("taro_toho_mouse","死亡后必定掉落一枚金币，有25%概率额外掉落四枚金币")
	register_enemy_info_island("water_taro_toho_mouse","死亡后必定掉落一枚金币，有25%概率额外掉落四枚金币")
	register_enemy_info_island("assault_mouse","会从水里突然出现。\nTip：记得提前给靠前的重要卡片套上瓜皮。")
	register_enemy_info_island("frog_prince_mouse","跳入水中后以2.25的速度移动，遇到第一个卡片后会翻越，并落在该卡片的\n后面一格，随后移动速度降低至0.3。无法越过重型防御。\nTip：可以利用低耗火的卡片使其提前翻越。")
	register_enemy_info_island("roller_skating_mouse","轮滑鞋和护具让它非常耐揍，且速度更快")
	register_enemy_info_island("giant_mouse","巨型老鼠，会对你的防御卡造成毁灭性打击。\nTip：可以利用冷却快的卡片诱使其攻击，拖延其前进")
	register_enemy_info_island("mario_mouse","BOSS单位不会按常规方式移动，而是遵守以下循环：\n洞君会在地图右侧出场，并使用下列技能的随机一个，随后消失。\n技能1：洞君会在地图第9列挖掘一个坑洞，并在4-7列的范围内随机生成一\n个生命值为600的管道，进入坑洞的老鼠会被传送到管道处。\n技能2：洞君会进行3次跳跃，依次摧毁本行第8、6、4列的三张卡片。")
	register_enemy_info_island("arno","阿诺会在地图右侧出场，并使用下列技能的随机一个，随后消失。\n技能1：阿诺发射一颗子弹，摧毁本行最左侧的一张卡片。\n技能2：阿诺在较长前摇后冲刺，摧毁本行右侧5列的卡片。")
	register_enemy_info_island("temple_pharaoh","法老原形会在地图右侧出场，并使用下列技能的随机一个，随后消失。\n技能1：法老原形在地图上随机4格召唤绷带，缠绕并摧毁本格卡片。\n技能2：法老原形在地图5-9列范围内随机召唤4个生命值为600的棺材，摧毁\n本格卡片，每个棺材处会生成一只生命值为200的木乃伊鼠。")
	register_enemy_info_island("engineering_vehicle_mouse","当自身前方存在可攻击的卡片时，会停车瞄准本行最左侧的一张卡片，每5\n秒投掷一个10点伤害的土块，土块能够伤害护罩内部的植物。如果卡片离自\n己太近，则会进行碾压。\nTip：将高生命值的卡片摆在左侧，并使用鱼刺来对付它。")
	register_enemy_info_island("garbage_track_mouse","碾压碰到的卡片，并在后方留下垃圾，存在垃圾的格子将无法放置卡片。\n垃圾车鼠免疫减速和冰冻效果。\nTip：使用酒瓶炸弹烧毁垃圾，使用鱼刺扎破车胎。")
	register_enemy_info_island("mole","入场时以0.9的速度挖掘，到达最后一列后会破土而出并眩晕3秒，随后以\n0.15的速度向右行走。\nTip:在最后一列放置鱼刺，或者使用旋转咖啡喷壶和双向水管来击杀它。")
	register_enemy_info_island("glider_mouse","入场时以0.72的速度滑翔，飞到最后一列或者滑翔翼被摧毁后会落地，速度\n降低至0.36。\nTip:可以使用香肠、章鱼烧、旋转咖啡喷壶等卡片将它击落。")
	register_enemy_info_island("bat_mouse","蝙蝠鼠会在一个格子上放置标靶，随后偷走标记格子上的卡片。\n蝙蝠鼠在下降和返回时被视为空中目标，其余时刻被视为地面目标。")
	register_enemy_info_island("ice_residue","冰渣会在地图右侧出场，并使用下列技能的随机一个，随后消失。再次出现\n时，冰渣会随机切换形态。\n技能1：冰渣发射五个魔法球，摧毁本行最左侧的五张卡片。释放该技能时，\n冰渣可以被酒瓶炸弹打断，火渣可以被冰桶炸弹打断，打断后会在原地眩晕\n五秒。\n技能2：冰渣根据形态，在较长前摇后释放一个生命值为1300、速度为0.3的\n冰球或火球，碾压遇到的卡片。冰球可以被酒瓶炸弹摧毁，火球可以被冰桶\n炸弹摧毁。")
	register_enemy_info_island("rumble","轰隆隆会在地图右侧出场，并拥有以下技能组：\n技能1：轰隆隆移动至地图3-6列的随机位置，随后快速落地，摧毁2*2范围\n内的所有卡片。\n技能2：轰隆隆移动至地图右侧，随后发射1发导弹，摧毁地图上随机1个格\n子的卡片。\n技能3：轰隆隆移动至地图右侧，经过8秒的前摇后射出一束激光，摧毁本行\n的全部卡片。\n轰隆隆会使用1-2-1-3的技能循环。\n轰隆隆在移动、起飞和降落时被视为空中目标，其余时刻被视为地面目标。\n轰隆隆每次移动都需要花费3秒，且每次使用技能都会陷入5秒的后摇。")
	register_enemy_info_island("abyss_pharaoh","法老鼠会在地图右侧出场，并拥有以下技能组：\n技能1：法老鼠会进行4次召唤，每次会在随机一个陆地行的8-9列召唤一只\n生命值为500、速度为1.8的圣甲虫，圣甲虫会对第一个碰到的卡片造成2000\n点伤害，造成伤害后消失。\n技能2：法老鼠在地图上随机6格召唤绷带，缠绕并摧毁本格卡片。\n技能3：法老鼠在地图5-9列范围内随机召唤4个生命值为600的棺材，摧毁本\n格卡片，每个棺材处会生成一只生命值为200的木乃伊鼠。\n法老鼠会使用1-2-3的技能循环，且每次移动都需要花费3秒。")
	register_enemy_info_island("cucumber_paper_boat_mouse","很普通的水上老鼠，没有特殊能力。")
	register_enemy_info_island("apple_duck_mouse","足球帽使它的脑门更硬了。")
	register_enemy_info_island("egg_tropical_fish_mouse","头顶的铁锅使它能够承受大量伤害。")
	register_enemy_info_island("orange_prince_mouse","跳入水中后以2.25的速度移动，遇到第一个卡片后会翻越，并落在该卡片的\n后面一格，随后移动速度降低至0.3。无法越过重型防御。\nTip：可以利用低耗火的卡片使其提前翻越。")
	register_enemy_info_island("submarine_mouse","生命值极高，且速度很快，会对你的防线造成很大威胁。")
	register_enemy_info_island("rowboat_mouse","会从第八列入场，并且秒杀卡片。每前进两格，就会后退一格。")
	register_enemy_info_island("water_penguin_mouse","入场后，如果碰到卡片，则会向本行最左侧的一张卡片投掷冰炸弹，冰炸弹\n会将3*3范围内的卡片冰冻4秒并减速10秒。如果没有碰到卡片，则会在7秒\n后投掷冰炸弹。")
	register_enemy_info_island("pink_paul","粉红保罗会在水池中出场，并使用下列技能的随机一个，随后消失。\n技能1：粉红保罗连续发射四个海星，摧毁随机4格的卡片。\n技能2：粉红保罗在2-6列的随机行钻出水面，随后使用触手拍打，摧毁十字\n范围上的四张卡片。\n粉红保罗每次钻出水面都会摧毁本格卡片。")
	register_enemy_info_island("cucumber_normal_mouse","很普通的老鼠，没有特殊能力。遇到可攻击的卡片就会啃食。")
	register_enemy_info_island("apple_football_fan_mouse","足球帽使它的脑门更硬了。")
	register_enemy_info_island("egg_iron_pan_mouse","头顶的铁锅使它能够承受大量伤害。")
	register_enemy_info_island("tangerine_skateboard_mouse","入场时以0.9的速度移动，遇到第一个卡片后，会使用滑板翻越该卡片，并\n落至该卡片的后面一格，落地后移动速度降低至0.3。无法越过重型防御。\nTip：可以将低耗火的卡放在它面前，使其提前使用滑板。")
	register_enemy_info_island("shy_landlady_mouse","盾牌可以抵挡直射伤害，并免疫其带来的负面效果，但是无法抵挡投掷和穿\n透伤害。")
	register_enemy_info_island("zombie_with_wallnut","入场时以0.36的速度移动，坚果被击落后，会进入发怒状态，速度提高至\n0.6，攻击间隔减半。")
	register_enemy_info_island("caribbean_mouse","会随着一大波老鼠一起出现。")
	register_enemy_info_island("penguin_mouse","入场后，如果碰到卡片，则会向本行最左侧的一张卡片投掷冰炸弹，冰炸弹\n会将3*3范围内的卡片冰冻4秒并减速10秒。如果没有碰到卡片，则会在7秒\n后投掷冰炸弹。")
	register_enemy_info_island("arson_mouse","入场后，如果碰到卡片，则会向本行最左侧的一张卡片投掷炸弹，炸弹会摧\n毁3*3范围内的卡片。如果没有碰到卡片，则会在7秒后投掷炸弹。投掷后速\n度降低至0.3。")
	register_enemy_info_island("non_mainstream_mouse","使用华丽的舞步躲避子弹，但是无法躲避咖啡喷雾、鱼刺、炸弹等非实体伤\n害。啃食时无法躲避子弹。")
	register_enemy_info_island("flute_mouse","入场5秒后会奏响笛子，为场上所有敌人恢复200点生命值，如果该敌人的生\n命上限不足200则会补足200。首次吹奏后，每10秒都会再次吹奏笛子。")
	register_enemy_info_island("panda_mouse","巨型老鼠，会对你的防御卡造成毁灭性打击。\n生命值降低至一半时，如果自身在第五列之外，则会向第3或4列投掷一只生\n命值为100的小熊猫鼠。\nTip：可以利用冷却快的卡片诱使其攻击，拖延其前进")
	register_enemy_info_island("can_mouse","第一次遇到爆炸时，会免疫伤害，并借助爆炸动力向前跳跃，随后扔下罐头。\n失去罐头后无法免疫爆炸。\nTip：猫猫箱可以将罐头吓掉。")
	register_enemy_info_island("blonde_mary","金发玛丽会在地图中出场，并拥有以下技能组：\n技能1：金发玛丽从第四列的随机行出现，来回移动并摧毁两次最后四列的\n卡片。\n技能2：金发玛丽从第4行第9列出现，扔出回旋镖，摧毁圆形范围的卡片。\n技能3：金发玛丽从第9列的随机行出现，并催眠全场卡片5秒。\n金发玛丽会使用1-2-1-3的技能循环。")
	register_enemy_info_island("pete","钢爪皮特会在地图中出场，并拥有以下技能组：\n技能1：钢爪皮特在2-6列的随机行出现并进行踩踏，摧毁3*3范围内的所有\n卡片。\n技能2：钢爪皮特出现在第6列的随机行，在全场随机位置召唤5个生命值为\n900的钢爪，钢爪会在3秒后摧毁本格卡片。\n技能3：钢爪皮特出现在第9列的随机行，向随机6个格子发射导弹，摧毁该\n格卡片。\n技能4：钢爪皮特出现在第6列的随机行，在第5列召唤一列生命值为2500的\n尖刺，持续8秒。\n钢爪皮特会使用1-2-3-4的技能循环。")
	register_enemy_info_island("ghost_mouse","入场时处于隐身状态，免疫绝大多数伤害，但无法免疫炸弹伤害。\n处于油灯范围内时会显形，失去免疫效果。")
	register_enemy_info_island("magician_mouse","入场后，每8秒向5-7列的范围内发射一只生命值为100的小魔术师鼠。")
	register_enemy_info_island("flight_barrier_mouse","入场后以0.72的速度滑翔，到达第5-7列后会丢下一个生命值为10000的障碍\n物并落地，落地后速度降低至0.36")
	register_enemy_info_island("hells_messenger","地狱屎者会在地图右侧出场，并拥有以下技能组：\n技能1：地狱屎者召唤5团鬼火，它们会移动至随机行并变成一只幽灵鼠。\n技能2：地狱屎者将权杖扔到4行5列，权杖拥有5000点生命值，并且会持续\n吸收场上的火苗。\n技能3：地狱屎者在短暂思考后，将场上随机4格的卡片吸入口中。\n技能4：地狱屎者在2-6列的随机行留下一坨生命值为900的便便，便便会在3\n秒后摧毁十字范围内的卡片，随后拿回权杖。\n地狱屎者会使用1-2-3-4的技能循环。")
	register_enemy_info_island("needle_baron","针头男爵会在地图右侧出场，并拥有以下技能组：\n技能1：针头男爵召唤3群生命值为900的蝙蝠，它们会移动至随机格，并在3\n秒后摧毁本格卡片。\n技能2：针头男爵移动至随机一张卡片处，并使用针管吸收卡片，每吸收一\n张卡片都会回复1000点生命值，并在卡片处留下一只木乃伊鼠。\n技能3：针头男爵移动至第一行或第七行的第九列，摧毁斜向范围的五张卡\n片。\n针头男爵会使用1-2-3的技能循环。")
	register_enemy_info_island("fog_julie","迷雾朱莉会在地图右侧出场，并拥有以下技能组：\n技能1：初次使用时，迷雾朱莉会从第一行逐渐移动至第七行，移动过程中\n会生成迷雾。再次使用时会移动到第九列的随机行。\n技能2：迷雾朱莉移动到3-7列的随机行并丢下燃烧弹，摧毁5格范围的卡片。\n技能3：迷雾朱莉移动到第九列的随机行并落地，为全场敌人进行两次600点\n生命值的回复，为生命上限不足600的敌人补足600。\n技能4：迷雾朱莉召唤嗡嗡中尉进行支援，随后起飞。\n迷雾朱莉会使用1-2-3-4-2的技能循环。\n召唤出的嗡嗡中尉会在迷雾朱莉死亡后退场。")
	register_enemy_info_island("lieutenant_buzz","嗡嗡中尉会在地图右侧出场，并拥有以下技能组：\n技能1：嗡嗡中尉发射3个龙卷风，摧毁随机三格的卡片。\n技能2：嗡嗡中尉连续将3只苹果球迷鼠送至第3-7列的随机行。\n技能3：嗡嗡中尉进行扫射，摧毁本行第2-6列的五张卡片。\n技能4：嗡嗡中尉向上飞离屏幕，期间留下3只伞兵鼠。\n嗡嗡中尉会使用1-2-3-4的技能循环。")
	register_enemy_info_island("paratrooper_mouse","入场时为空中单位，会随机选择一个3列以外格子落地，落地后在本格卡片\n上覆盖一个生命值为420的瓜皮罩，并转变为陆地单位。")
	register_enemy_info_island("irritable_jack","暴躁杰克会在地图右侧出场，并拥有以下技能组：\n技能1：暴躁杰克跳跃至本行第2-5列的随机列，随后使用拳头锤击，摧毁3\n格范围内的卡片。\n技能2：暴躁杰克将身体分解为7个滚石并分散至每一行，核心的生命值与自\n身相同，其余滚石生命值为1800。滚石会摧毁路径上的全部卡片并在第四列\n消失。\n技能3：暴躁杰克使用身体部位砸击摧毁随机5个格子的卡片，随后重组。\n技能4：暴躁杰克连续召唤3个生命值为900的火老鼠，火老鼠会对第一个碰\n到的卡片造成2000点伤害。\n暴躁杰克会使用1-2-3-4的技能循环。")
	register_enemy_info_island("hot_vajra","炽热金刚会在地图中出场，并拥有以下技能组：\n技能1：炽热金刚在2-6列的随机行出现并进行踩踏，摧毁3*3范围内的所有\n卡片。\n技能2：炽热金刚向随机5个格子发射岩浆块，使这些格子覆盖持续30秒的岩\n浆。\n技能3：炽热金刚在地图四条边上召唤4个生命值为1200的电流尖刺，如果没\n有在8秒内摧毁这些尖刺，则这些尖刺连线上的所有卡片都会被摧毁。\n技能4：炽热金刚解体为钢爪皮特和迷雾朱莉，两个BOSS各继承炽热金刚的\n一半生命值。50秒后，炽热金刚会重新合体，并将两个BOSS受到的伤害结算\n至自身。如果解体期间任意一个BOSS被击败，则无法合体。\n炽热金刚会使用1-2-3-4的技能循环。")
}